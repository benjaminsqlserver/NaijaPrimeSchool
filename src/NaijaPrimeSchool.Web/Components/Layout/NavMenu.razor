@* Primary navigation rendered inside the Radzen sidebar *@

<RadzenPanelMenu class="nps-panel-menu">
    <RadzenPanelMenuItem Text="Dashboard" Icon="dashboard" Path="/" />

    <AuthorizeView Roles="@(Roles.SuperAdmin)">
        <Authorized>
            <RadzenPanelMenuItem Text="User Management" Icon="manage_accounts" Expanded="true">
                <RadzenPanelMenuItem Text="All Users" Icon="people" Path="/users" />
                <RadzenPanelMenuItem Text="Add New User" Icon="person_add" Path="/users/new" />
                <RadzenPanelMenuItem Text="Roles" Icon="admin_panel_settings" Path="/roles" />
            </RadzenPanelMenuItem>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@($"{Roles.SuperAdmin},{Roles.HeadTeacher},{Roles.Teacher}")">
        <Authorized>
            <RadzenPanelMenuItem Text="Academics" Icon="school" Expanded="true">
                <RadzenPanelMenuItem Text="Sessions" Icon="event" Path="/sessions" />
                <RadzenPanelMenuItem Text="Terms" Icon="event_note" Path="/terms" />
                <RadzenPanelMenuItem Text="Classes" Icon="class" Path="/classes" />
                <RadzenPanelMenuItem Text="Subjects" Icon="menu_book" Path="/subjects" />
                <RadzenPanelMenuItem Text="Periods" Icon="schedule" Path="/timetable-periods" />
                <RadzenPanelMenuItem Text="Timetable" Icon="grid_on" Path="/timetable" />
            </RadzenPanelMenuItem>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@($"{Roles.SuperAdmin},{Roles.HeadTeacher}")">
        <Authorized>
            <RadzenPanelMenuItem Text="Family" Icon="family_restroom" Expanded="true">
                <RadzenPanelMenuItem Text="Students" Icon="boy" Path="/students" />
                <RadzenPanelMenuItem Text="Add Student" Icon="person_add" Path="/students/new" />
                <RadzenPanelMenuItem Text="Parents" Icon="people_outline" Path="/parents" />
                <RadzenPanelMenuItem Text="Add Parent" Icon="group_add" Path="/parents/new" />
                <RadzenPanelMenuItem Text="Enrolments" Icon="how_to_reg" Path="/enrolments" />
            </RadzenPanelMenuItem>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@($"{Roles.SuperAdmin},{Roles.HeadTeacher},{Roles.Teacher}")">
        <Authorized>
            <RadzenPanelMenuItem Text="Attendance" Icon="event_available" Expanded="true">
                <RadzenPanelMenuItem Text="Daily attendance" Icon="today" Path="/attendance/daily" />
                <RadzenPanelMenuItem Text="Subject attendance" Icon="schedule" Path="/attendance/subject" />
                <RadzenPanelMenuItem Text="Summary" Icon="analytics" Path="/attendance/summary" />
            </RadzenPanelMenuItem>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@($"{Roles.SuperAdmin},{Roles.SchoolBursar}")">
        <Authorized>
            <RadzenPanelMenuItem Text="Finance" Icon="payments" Disabled="true" />
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@($"{Roles.SuperAdmin},{Roles.SchoolStoreKeeper}")">
        <Authorized>
            <RadzenPanelMenuItem Text="Store & Inventory" Icon="inventory_2" Disabled="true" />
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@($"{Roles.Parent},{Roles.Student}")">
        <Authorized>
            <RadzenPanelMenuItem Text="My Children" Icon="family_restroom" Disabled="true" />
        </Authorized>
    </AuthorizeView>
</RadzenPanelMenu>
