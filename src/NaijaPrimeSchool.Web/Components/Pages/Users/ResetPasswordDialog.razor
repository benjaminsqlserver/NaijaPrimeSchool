@inject DialogService DialogService

<div style="padding: 0.5rem 0;">
    <div class="nps-field">
        <label>New password</label>
        <RadzenPassword @bind-Value="password" AutoComplete="false" />
    </div>
    <div class="nps-field" style="margin-top: 0.75rem;">
        <label>Confirm password</label>
        <RadzenPassword @bind-Value="confirm" AutoComplete="false" />
    </div>
    @if (!string.IsNullOrEmpty(error))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter" AllowClose="false">@error</RadzenAlert>
    }
    <div style="display:flex; gap:.5rem; justify-content:flex-end; margin-top:1rem;">
        <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat"
                      Click="@(() => DialogService.Close(null))" />
        <RadzenButton Text="Update password" ButtonStyle="ButtonStyle.Primary"
                      Click="@Submit" />
    </div>
</div>

@code {
    private string password = string.Empty;
    private string confirm = string.Empty;
    private string? error;

    private void Submit()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(password) || password.Length < 8)
        {
            error = "Password must be at least 8 characters.";
            return;
        }
        if (!string.Equals(password, confirm, StringComparison.Ordinal))
        {
            error = "Passwords do not match.";
            return;
        }
        DialogService.Close(password);
    }
}
