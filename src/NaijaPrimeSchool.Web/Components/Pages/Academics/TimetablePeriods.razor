@page "/timetable-periods"
@using NaijaPrimeSchool.Application.Academics
@using NaijaPrimeSchool.Application.Academics.Dtos
@attribute [Authorize(Roles = $"{Roles.SuperAdmin},{Roles.HeadTeacher}")]
@rendermode InteractiveServer

@inject ITimetableService TimetableService
@inject NotificationService Notification
@inject DialogService Dialog

<PageTitle>Periods · Naija Prime School</PageTitle>

<div class="nps-page-header">
    <div>
        <h1>Timetable periods</h1>
        <p>The slots in a school day. The timetable grid uses these in display order.</p>
    </div>
    <div class="nps-page-actions">
        <RadzenButton Text="New period" Icon="add" ButtonStyle="ButtonStyle.Primary"
                      Click="@(() => OpenForm(null))" />
    </div>
</div>

<RadzenCard class="nps-card">
    <RadzenDataGrid TItem="TimetablePeriodDto" Data="@periods" IsLoading="@loading"
                    AllowPaging="false" EmptyText="No periods configured.">
        <Columns>
            <RadzenDataGridColumn TItem="TimetablePeriodDto" Title="Order" Property="DisplayOrder" Width="100px" />
            <RadzenDataGridColumn TItem="TimetablePeriodDto" Title="Name" Property="Name" />
            <RadzenDataGridColumn TItem="TimetablePeriodDto" Title="Start" Property="StartTime" FormatString="{0:hh\\:mm}" Width="100px" />
            <RadzenDataGridColumn TItem="TimetablePeriodDto" Title="End"   Property="EndTime"   FormatString="{0:hh\\:mm}" Width="100px" />
            <RadzenDataGridColumn TItem="TimetablePeriodDto" Title="Type" Width="120px">
                <Template Context="p">
                    <RadzenBadge Text="@(p.IsBreak ? "Break" : "Lesson")"
                                 BadgeStyle="@(p.IsBreak ? BadgeStyle.Warning : BadgeStyle.Info)"
                                 Variant="Variant.Flat" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="TimetablePeriodDto" Title="Actions" Sortable="false" Width="160px" TextAlign="TextAlign.Right">
                <Template Context="p">
                    <div class="nps-inline-actions">
                        <RadzenButton Icon="edit" Size="ButtonSize.Small" Variant="Variant.Flat"
                                      ButtonStyle="ButtonStyle.Light" Click="@(() => OpenForm(p))" title="Edit" />
                        <RadzenButton Icon="delete" Size="ButtonSize.Small" Variant="Variant.Flat"
                                      ButtonStyle="ButtonStyle.Danger" Click="@(() => DeleteAsync(p))" title="Delete" />
                    </div>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenCard>

@if (showForm)
{
    <RadzenCard class="nps-card" Style="margin-top:1rem;">
        <h3 style="margin:0 0 1rem;">@(editingId.HasValue ? "Edit period" : "New period")</h3>
        <RadzenTemplateForm TItem="PeriodFormModel" Data="@form" Submit="@SaveAsync">
            <DataAnnotationsValidator />
            <div class="nps-form-grid">
                <div class="nps-field">
                    <label>Name *</label>
                    <RadzenTextBox @bind-Value="form.Name" Placeholder="Period 1" />
                    <ValidationMessage For="() => form.Name" />
                </div>
                <div class="nps-field">
                    <label>Display order</label>
                    <RadzenNumeric TValue="int" @bind-Value="form.DisplayOrder" Min="1" />
                </div>
                <div class="nps-field">
                    <label>Start time *</label>
                    <RadzenDatePicker TValue="DateTime?" @bind-Value="form.StartTime"
                                      ShowTime="true" ShowDate="false" TimeOnly="true" DateFormat="HH:mm" HourFormat="24" />
                </div>
                <div class="nps-field">
                    <label>End time *</label>
                    <RadzenDatePicker TValue="DateTime?" @bind-Value="form.EndTime"
                                      ShowTime="true" ShowDate="false" TimeOnly="true" DateFormat="HH:mm" HourFormat="24" />
                </div>
                <div class="nps-field">
                    <label>Break period</label>
                    <RadzenSwitch @bind-Value="form.IsBreak" />
                </div>
            </div>
            <div class="nps-form-actions">
                <RadzenButton Text="Cancel" ButtonType="ButtonType.Button"
                              ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat"
                              Click="@(() => showForm = false)" />
                <RadzenButton Text="@(saving ? "Saving..." : "Save")"
                              Icon="save" ButtonType="ButtonType.Submit"
                              ButtonStyle="ButtonStyle.Primary" Disabled="@saving" />
            </div>
        </RadzenTemplateForm>
    </RadzenCard>
}

@code {
    private IReadOnlyList<TimetablePeriodDto> periods = [];
    private bool loading;
    private bool saving;
    private bool showForm;
    private Guid? editingId;

    private PeriodFormModel form = new();

    private class PeriodFormModel
    {
        [System.ComponentModel.DataAnnotations.Required, System.ComponentModel.DataAnnotations.StringLength(40)]
        public string Name { get; set; } = string.Empty;

        public int DisplayOrder { get; set; } = 1;
        public DateTime? StartTime { get; set; }
        public DateTime? EndTime { get; set; }
        public bool IsBreak { get; set; }
    }

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        loading = true;
        try { periods = await TimetableService.ListPeriodsAsync(); }
        finally { loading = false; }
    }

    private void OpenForm(TimetablePeriodDto? p)
    {
        editingId = p?.Id;
        var today = DateTime.Today;
        form = new PeriodFormModel
        {
            Name = p?.Name ?? string.Empty,
            DisplayOrder = p?.DisplayOrder ?? (periods.Count + 1),
            StartTime = p is null ? null : today.Add(p.StartTime.ToTimeSpan()),
            EndTime = p is null ? null : today.Add(p.EndTime.ToTimeSpan()),
            IsBreak = p?.IsBreak ?? false,
        };
        showForm = true;
    }

    private async Task SaveAsync()
    {
        if (form.StartTime is null || form.EndTime is null)
        {
            Notification.Notify(NotificationSeverity.Warning, "Required", "Start and end time are required.");
            return;
        }

        saving = true;
        try
        {
            var start = TimeOnly.FromDateTime(form.StartTime.Value);
            var end = TimeOnly.FromDateTime(form.EndTime.Value);

            OperationResult result = editingId.HasValue
                ? await TimetableService.UpdatePeriodAsync(new UpdateTimetablePeriodRequest
                {
                    Id = editingId.Value,
                    Name = form.Name,
                    StartTime = start,
                    EndTime = end,
                    DisplayOrder = form.DisplayOrder,
                    IsBreak = form.IsBreak,
                })
                : await TimetableService.CreatePeriodAsync(new CreateTimetablePeriodRequest
                {
                    Name = form.Name,
                    StartTime = start,
                    EndTime = end,
                    DisplayOrder = form.DisplayOrder,
                    IsBreak = form.IsBreak,
                });

            if (result.Succeeded)
            {
                Notification.Notify(NotificationSeverity.Success, "Saved", $"Period '{form.Name}' saved.");
                showForm = false;
                await LoadAsync();
            }
            else
            {
                Notification.Notify(NotificationSeverity.Error, "Failed", string.Join("; ", result.Errors));
            }
        }
        finally
        {
            saving = false;
        }
    }

    private async Task DeleteAsync(TimetablePeriodDto p)
    {
        var confirm = await Dialog.Confirm($"Delete period '{p.Name}'?", "Confirm delete",
            new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel" });
        if (confirm != true) return;

        var result = await TimetableService.SoftDeletePeriodAsync(p.Id);
        if (result.Succeeded)
        {
            Notification.Notify(NotificationSeverity.Success, "Deleted", $"Period '{p.Name}' deleted.");
            await LoadAsync();
        }
        else
        {
            Notification.Notify(NotificationSeverity.Error, "Failed", string.Join("; ", result.Errors));
        }
    }
}
