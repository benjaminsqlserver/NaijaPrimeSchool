@page "/terms"
@using NaijaPrimeSchool.Application.Academics
@using NaijaPrimeSchool.Application.Academics.Dtos
@attribute [Authorize(Roles = $"{Roles.SuperAdmin},{Roles.HeadTeacher}")]
@rendermode InteractiveServer

@inject ITermService TermService
@inject ISessionService SessionService
@inject ILookupService LookupService
@inject NotificationService Notification
@inject DialogService Dialog

<PageTitle>Terms · Naija Prime School</PageTitle>

<div class="nps-page-header">
    <div>
        <h1>Terms</h1>
        <p>First, second, and third terms scheduled inside each academic session.</p>
    </div>
    <div class="nps-page-actions">
        <RadzenButton Text="New term" Icon="add" ButtonStyle="ButtonStyle.Primary"
                      Click="@(() => OpenForm(null))" />
    </div>
</div>

<RadzenCard class="nps-card" Style="margin-bottom:1rem;">
    <div class="nps-filter-bar">
        <div class="nps-field">
            <label>Filter by session</label>
            <RadzenDropDown TValue="Guid?" Data="@sessions" TextProperty="Name" ValueProperty="Id"
                            @bind-Value="filterSessionId" AllowClear="true" Placeholder="All sessions"
                            Change="@(_ => LoadAsync())" Style="min-width: 240px;" />
        </div>
    </div>
</RadzenCard>

<RadzenCard class="nps-card">
    <RadzenDataGrid TItem="TermDto" Data="@terms" IsLoading="@loading"
                    AllowPaging="true" PageSize="20" EmptyText="No terms yet.">
        <Columns>
            <RadzenDataGridColumn TItem="TermDto" Title="Session" Property="SessionName" />
            <RadzenDataGridColumn TItem="TermDto" Title="Term" Property="TermTypeName">
                <Template Context="t">
                    @t.TermTypeName
                    @if (t.IsCurrent)
                    {
                        <RadzenBadge Text="Current" BadgeStyle="BadgeStyle.Success"
                                     Variant="Variant.Flat" Style="margin-left:.5rem;" />
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="TermDto" Title="Start" Property="StartDate" FormatString="{0:d MMM yyyy}" Width="140px" />
            <RadzenDataGridColumn TItem="TermDto" Title="End"   Property="EndDate"   FormatString="{0:d MMM yyyy}" Width="140px" />
            <RadzenDataGridColumn TItem="TermDto" Title="Actions" Sortable="false" Width="220px" TextAlign="TextAlign.Right">
                <Template Context="t">
                    <div class="nps-inline-actions">
                        @if (!t.IsCurrent)
                        {
                            <RadzenButton Icon="check_circle" Size="ButtonSize.Small"
                                          ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat"
                                          title="Mark current"
                                          Click="@(() => SetCurrentAsync(t))" />
                        }
                        <RadzenButton Icon="edit" Size="ButtonSize.Small" Variant="Variant.Flat"
                                      ButtonStyle="ButtonStyle.Light" title="Edit"
                                      Click="@(() => OpenForm(t))" />
                        <RadzenButton Icon="delete" Size="ButtonSize.Small" Variant="Variant.Flat"
                                      ButtonStyle="ButtonStyle.Danger" title="Delete"
                                      Click="@(() => DeleteAsync(t))" />
                    </div>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenCard>

@if (showForm)
{
    <RadzenCard class="nps-card" Style="margin-top:1rem;">
        <h3 style="margin:0 0 1rem;">@(editingId.HasValue ? "Edit term" : "New term")</h3>
        <RadzenTemplateForm TItem="TermFormModel" Data="@form" Submit="@SaveAsync">
            <DataAnnotationsValidator />
            <div class="nps-form-grid">
                <div class="nps-field">
                    <label>Session *</label>
                    <RadzenDropDown TValue="Guid?" Data="@sessions" TextProperty="Name" ValueProperty="Id"
                                    @bind-Value="form.SessionId" Placeholder="Pick a session" />
                </div>
                <div class="nps-field">
                    <label>Term *</label>
                    <RadzenDropDown TValue="Guid?" Data="@termTypes" TextProperty="Name" ValueProperty="Id"
                                    @bind-Value="form.TermTypeId" Placeholder="Pick a term" />
                </div>
                <div class="nps-field">
                    <label>Start date *</label>
                    <RadzenDatePicker TValue="DateTime?" @bind-Value="form.StartDate"
                                      DateFormat="d MMM yyyy" ShowTime="false" />
                </div>
                <div class="nps-field">
                    <label>End date *</label>
                    <RadzenDatePicker TValue="DateTime?" @bind-Value="form.EndDate"
                                      DateFormat="d MMM yyyy" ShowTime="false" />
                </div>
                <div class="nps-field">
                    <label>Mark current</label>
                    <RadzenSwitch @bind-Value="form.IsCurrent" />
                </div>
            </div>
            <div class="nps-form-actions">
                <RadzenButton Text="Cancel" ButtonType="ButtonType.Button"
                              ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat"
                              Click="@(() => showForm = false)" />
                <RadzenButton Text="@(saving ? "Saving..." : "Save")"
                              Icon="save" ButtonType="ButtonType.Submit"
                              ButtonStyle="ButtonStyle.Primary" Disabled="@saving" />
            </div>
        </RadzenTemplateForm>
    </RadzenCard>
}

@code {
    private IReadOnlyList<TermDto> terms = [];
    private IReadOnlyList<SessionDto> sessions = [];
    private IReadOnlyList<LookupDto> termTypes = [];
    private bool loading;
    private bool saving;
    private bool showForm;
    private Guid? editingId;
    private Guid? filterSessionId;

    private TermFormModel form = new();

    private class TermFormModel
    {
        public Guid? SessionId { get; set; }
        public Guid? TermTypeId { get; set; }
        public DateTime? StartDate { get; set; }
        public DateTime? EndDate { get; set; }
        public bool IsCurrent { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        sessions = await SessionService.ListAsync();
        termTypes = await LookupService.GetTermTypesAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loading = true;
        try { terms = await TermService.ListAsync(filterSessionId); }
        finally { loading = false; }
    }

    private void OpenForm(TermDto? t)
    {
        editingId = t?.Id;
        form = new TermFormModel
        {
            SessionId = t?.SessionId,
            TermTypeId = t?.TermTypeId,
            StartDate = t is null ? null : t.StartDate.ToDateTime(TimeOnly.MinValue),
            EndDate = t is null ? null : t.EndDate.ToDateTime(TimeOnly.MinValue),
            IsCurrent = t?.IsCurrent ?? false,
        };
        showForm = true;
    }

    private async Task SaveAsync()
    {
        if (form.SessionId is null || form.TermTypeId is null
            || form.StartDate is null || form.EndDate is null)
        {
            Notification.Notify(NotificationSeverity.Warning, "Required",
                "Session, term, and both dates are required.");
            return;
        }

        saving = true;
        try
        {
            var start = DateOnly.FromDateTime(form.StartDate.Value);
            var end = DateOnly.FromDateTime(form.EndDate.Value);

            OperationResult result;
            if (editingId.HasValue)
            {
                result = await TermService.UpdateAsync(new UpdateTermRequest
                {
                    Id = editingId.Value,
                    SessionId = form.SessionId.Value,
                    TermTypeId = form.TermTypeId.Value,
                    StartDate = start,
                    EndDate = end,
                    IsCurrent = form.IsCurrent,
                });
            }
            else
            {
                result = await TermService.CreateAsync(new CreateTermRequest
                {
                    SessionId = form.SessionId.Value,
                    TermTypeId = form.TermTypeId.Value,
                    StartDate = start,
                    EndDate = end,
                    IsCurrent = form.IsCurrent,
                });
            }

            if (result.Succeeded)
            {
                Notification.Notify(NotificationSeverity.Success, "Saved", "Term saved.");
                showForm = false;
                await LoadAsync();
            }
            else
            {
                Notification.Notify(NotificationSeverity.Error, "Failed", string.Join("; ", result.Errors));
            }
        }
        finally
        {
            saving = false;
        }
    }

    private async Task SetCurrentAsync(TermDto t)
    {
        var result = await TermService.SetCurrentAsync(t.Id);
        if (result.Succeeded)
        {
            Notification.Notify(NotificationSeverity.Success, "Current term", $"{t.SessionName} {t.TermTypeName} is now current.");
            await LoadAsync();
        }
    }

    private async Task DeleteAsync(TermDto t)
    {
        var confirm = await Dialog.Confirm($"Delete {t.SessionName} {t.TermTypeName}?",
            "Confirm delete", new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel" });
        if (confirm != true) return;

        var result = await TermService.SoftDeleteAsync(t.Id);
        if (result.Succeeded)
        {
            Notification.Notify(NotificationSeverity.Success, "Deleted", "Term deleted.");
            await LoadAsync();
        }
        else
        {
            Notification.Notify(NotificationSeverity.Error, "Failed", string.Join("; ", result.Errors));
        }
    }
}
